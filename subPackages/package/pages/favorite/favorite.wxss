page {
  background-color: #f5f5f5;
}

.page {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 顶部 */
.header {
  padding: 20rpx 10rpx 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

/* 居中状态 */
.center {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.empty-text {
  color: #999;
}

/* 列表容器 */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单个商品小方块 */
.item-box {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  /* 最多显示两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price-row {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e64340;
}

.price-old {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
}

/* 规格小方块区域 */
.specs-row {
  margin-top: 12rpx;
}

.specs-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

/* 规格小方块标签 */
.spec-tag {
  font-size: 22rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
}

/* 已收藏的规格高亮 */
.spec-tag.saved {
  color: #7546af;
  background-color: #f8f4ff;
  border-color: #e8d9ff;
}