<view class="container">
  <view class="order-settlement">
    <view class="shop-info">
      <view class="info-detail">
        <text class="item-adress" wx:if="{{selected === '外送'}}">{{address}}</text>
        <text class="item-adress" wx:else>{{storeName}}</text>
        <text class="user-id" wx:if="{{selected === '外送'}}">{{phone}} {{username}}</text>

      </view>
      <view class="pickup-delivery-group">
        <navigator url="/subPackages/package/pages/ziti/ziti?type=jiesuan" class="pickup-button {{selected === '自提' ? 'active' : ''}}" bindtap="selectOption" data-option="自提">
          <text>自提</text>
        </navigator>
        <navigator url="/subPackages/package/pages/chooseLocation/chooseLocation?type=jiesuan" class="delivery-button {{selected === '外送' ? 'active' : ''}}" bindtap="selectOption" data-option="外送">
          <text>外送</text>
        </navigator>
      </view>
    </view>
    <view class="order-list">
      <view class="order-item" wx:for="{{items}}" wx:key="id">
        <view class="item">
          <image class="item-image" src="{{AUrl}}/jy/wxUserImg/106/{{item.img}}"></image>
          <view class="item-details">
            <text decode="true">{{item.title}}</text>
            <!-- <text class="item-description">{{item.desc}}</text> -->
            <text class="item-price">¥{{item.price}}</text>
            <text class="item-quantity">数量: {{item.num}}</text>
            <text class="item-customizations">定制选项：{{item.add}}</text>
          </view>
        </view>
      </view>
    </view>
    <!-- 优惠券选择 -->
    <view class="coupon-row" bindtap="couponSelect">
      <text class="label" style="margin-left: 30rpx;">优惠券</text>
      <text class="value" style="margin-right: 30rpx;">{{couponAvailable ? (selectedCouponText || '可用优惠券') : '暂无可用券'}}</text>
    </view>
    <view class="coupon-row" wx:if="{{selected === '外送'}}">
      <text class="label" style="margin-left: 30rpx;">配送费</text>
      <text class="value" style="margin-right: 30rpx;">¥{{delivery}}</text>
    </view>
    <view class="coupon-row">
      <text class="label" style="margin-left: 30rpx;">实付</text>
      <text class="value" style="margin-right: 30rpx;">¥{{selected === '自提' ? totalprice : (totalprice*1 + delivery*1)}}</text>
    </view>
    <!-- 支付方式 -->
    <view class="pay-methods coupon-row" style="margin-top: 20rpx; background: #fff; border-radius: 16rpx; padding: 20rpx;">
      <text class="section-title" style="margin-left: 10rpx;">支付方式</text>
      <radio-group bindchange="choosePayMethod">
        <label class="pay-item">
          <view class="pm-left">
            <view class="pm-icon icon-wechat"></view>
            <text class="pm-text">微信支付</text>
          </view>
          <radio class="pm-radio" value="wechat" checked="{{payMethod==='wechat'}}"></radio>
        </label>
        <label class="pay-item {{balanceDisabled ? 'disabled' : ''}}" bindtap="guardBalancePay">
          <view class="pm-left">
            <view class="pm-icon icon-balance"></view>
            <text class="pm-text">余额支付</text>
            <text class="pm-hint">可用 ¥{{funds.balance}}</text>
          </view>
          <radio class="pm-radio" value="balance" disabled="{{balanceDisabled}}" checked="{{payMethod==='balance'}}"></radio>
        </label>
        <label class="pay-item {{coffeeDisabled ? 'disabled' : ''}}" bindtap="guardCoffeePay">
          <view class="pm-left"pay>
            <view class="pm-icon icon-coffee"></view>
            <text class="pm-text">咖啡券支付</text>
            <text class="pm-hint">可用 ¥{{funds.coffee}}</text>
          </view>
          <radio class="pm-radio" value="coffee" disabled="{{coffeeDisabled}}" checked="{{payMethod==='coffee'}}"></radio>
        </label>
        <label class="pay-item {{depositDisabled ? 'disabled' : ''}}" bindtap="guardDepositPay">
          <view class="pm-left">
            <view class="pm-icon icon-deposit"></view>
            <text class="pm-text">储值卡支付</text>
            <text class="pm-hint">可用 ¥{{funds.deposit}}</text>
          </view>
          <radio class="pm-radio" value="deposit" disabled="{{depositDisabled}}" checked="{{payMethod==='deposit'}}"></radio>
        </label>
      </radio-group>
    </view>
    <!-- 备注（移入滚动容器内） -->
    <view class="section-box remark-box">
      <view class="section-title">备注特殊要求</view>
      <textarea class="remark-textarea" placeholder="请输入备注内容" bindinput="inputRemark" value="{{remark}}"></textarea>
    </view>
  </view>
  <view class="zhifu">
    <view wx:if="{{isShow}}" class="pay-button" bindtap="initiatePayment">提交订单</view>
    <view wx:else class="pay-button">提交订单</view>
  </view>

  <!-- 取餐方式 -->
  <view class="section-box pickup-box">
    <view class="section-title">取餐方式</view>
    <view class="pickup-options">
      <view class="pickup-btn {{dineType==='dine_in' ? 'active' : ''}}" bindtap="setDineType" data-type="dine_in">店内用餐</view>
      <view class="pickup-btn {{dineType==='takeaway' ? 'active' : ''}}" bindtap="setDineType" data-type="takeaway">自提带走</view>
    </view>
  </view>

 
