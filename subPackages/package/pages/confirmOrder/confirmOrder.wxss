page {
  background-color: #f7f7f7;
}

.container {
  padding: 30rpx;
}

.order-card {
  width: 95%;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 套餐头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.main-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}
.sub-title {
  font-size: 28rpx;
  color: #999;
}
.header-right .tag {
  background-color: #f0f0ff;
  color: #6a7efc;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

/* 支付方式行 */
.pay-row {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}
.pay-label {
  font-size: 28rpx;
  color: #666;
}
.pay-money {
  font-size: 28rpx;
  color: #6a7efc;
  font-weight: bold;
}
.pay-coupon {
  font-size: 28rpx;
  color: #ff9500;
  font-weight: bold;
}

/* 详情行 */
.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.detail-item {
  width: 48%;
  display: flex;
  justify-content: space-between;
}
.detail-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.tips {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.total-price {
  font-size: 28rpx;
  color: #333;
}

.total-price .amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #6a7efc;
}

.submit-btn {
  background-color: #6a7efc;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}