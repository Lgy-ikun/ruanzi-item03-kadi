page {
  background-color: #f7f7f7;
}

.container {
  padding: 30rpx;
}

.order-card {
  width: 95%;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 套餐头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.main-title {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}
.sub-title {
  font-size: 28rpx;
  color: #999;
}
.header-right .tag {
  background-color: #f0f0ff;
  color: #6a7efc;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

/* 支付方式行 */
.pay-row {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.pay-label {
  font-size: 28rpx;
  color: #666;
}
.pay-money {
  font-size: 28rpx;
  color: #6a7efc;
  font-weight: bold;
}
.pay-coupon {
  font-size: 28rpx;
  color: #ff9500;
  font-weight: bold;
}
.coupon-type-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}
.coupon-type-item {
  min-width: 140rpx;
  text-align: center;
  line-height: 52rpx;
  height: 52rpx;
  border-radius: 28rpx;
  border: 1rpx solid #ddd;
  color: #666;
  font-size: 24rpx;
  background: #fff;
}
.coupon-type-item--active {
  border-color: #6a7efc;
  color: #6a7efc;
  background: #eef1ff;
}
.pay-type-tip {
  display: block;
  color: #999;
  font-size: 24rpx;
}
.pay-option {
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pay-option--active {
  border-color: #6a7efc;
}
.pay-option-text {
  font-size: 26rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.pay-option-check {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #bbb;
  border-radius: 50%;
  background: #fff;
}
.pay-option-check--active {
  border-color: #6a7efc;
  background: #6a7efc;
  box-shadow: inset 0 0 0 8rpx #fff;
}
.purchase-row {
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.purchase-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.qty-box {
  display: flex;
  align-items: center;
  background-color: #f3f3f3;
  border-radius: 40rpx;
  padding: 6rpx 12rpx;
}
.qty-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 34rpx;
  color: #333;
}
.qty-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 详情行 */
.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.detail-item {
  width: 48%;
  display: flex;
  justify-content: space-between;
}
.detail-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.tips {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.total-price {
  font-size: 28rpx;
  color: #333;
}

.total-price .amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #6a7efc;
}

.submit-btn {
  background-color: #6a7efc;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}
.code-dialog-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}
.code-content {
  width: 86%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
}
.code-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  text-align: center;
  margin-bottom: 28rpx;
}
.input-container {
  display: flex;
  justify-content: space-between;
  position: relative;
}
.input-box {
  width: 84rpx;
  height: 84rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.input-box input {
  width: 100%;
  text-align: center;
}
.overlay {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 100%;
}
.ipt {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 2rpx;
  height: 2rpx;
  opacity: 0;
  z-index: -1;
}
.code-actions {
  margin-top: 34rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}
.dialog-btn {
  flex: 1;
  text-align: center;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
}
.cancel-btn {
  border: 1rpx solid #ddd;
  color: #666;
}
.confirm-btn {
  background-color: #6a7efc;
  color: #fff;
}
