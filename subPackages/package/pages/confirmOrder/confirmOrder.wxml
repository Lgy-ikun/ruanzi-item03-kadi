<view class="container">
  <view class="order-card">
    <view class="item-header">
      <view class="header-left">
        <text class="main-title">套餐</text>
        <text class="sub-title">{{packageName}}</text>
      </view>
    </view>

    <view class="pay-row">
      <text class="pay-type-tip">请选择支付方式</text>
      <view class="pay-option {{selectedCouponType === 'kafei' ? 'pay-option--active' : ''}}" data-type="kafei" bindtap="onSelectCouponType">
        <view class="pay-option-text">
          <text class="pay-label">支付：</text>
          <text class="pay-money">余额{{payAmount}}</text>
          <text class="pay-coupon"> + 咖啡券{{coffeeAmount}}</text>
        </view>
        <view class="pay-option-check {{selectedCouponType === 'kafei' ? 'pay-option-check--active' : ''}}"></view>
      </view>
      <view class="pay-option {{selectedCouponType === 'dianzi' ? 'pay-option--active' : ''}}" data-type="dianzi" bindtap="onSelectCouponType">
        <view class="pay-option-text">
          <text class="pay-label">支付：</text>
          <text class="pay-money">余额{{payAmount}}</text>
          <text class="pay-coupon"> + 电子券{{coffeeAmount}}</text>
        </view>
        <view class="pay-option-check {{selectedCouponType === 'dianzi' ? 'pay-option-check--active' : ''}}"></view>
      </view>
    </view>
    <view class="detail-row">
      <view class="detail-item">
        <text class="detail-label">咖啡券倍数</text>
        <text class="detail-value">{{multiple}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">赠送总咖啡券</text>
        <text class="detail-value">{{totalReturn}}</text>
      </view>
    </view>
    <view class="detail-row">
      <view class="detail-item">
        <text class="detail-label">总天数</text>
        <text class="detail-value">{{days}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">每日释放</text>
        <text class="detail-value">{{dailyReturn}}</text>
      </view>
    </view>
  </view>

  <view class="tips">本套餐支持余额+咖啡券或余额+电子券组合支付，购买后不可退款。</view>

  <view class="footer">
    <view class="total-price">
      <text>应付金额：</text>
      <text class="amount">{{totalAmount}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">立即支付</view>
  </view>
  <view wx:if="{{showCodeDialog}}" class="code-dialog-mask">
    <view class="code-content">
      <view class="code-title">请输入交易码</view>
      <view class="input-container" bindtap="handleGetFocus">
        <block wx:for="{{inputBoxes}}" wx:key="index">
          <view class="input-box">
            <input id="input-{{index}}" focus="false" type="number" value="{{item}}" disabled="true" maxlength="1" />
          </view>
        </block>
      </view>
      <input class="ipt" value="{{codeValue}}" focus="{{testFocus}}" type="number" bindinput="handleTestInput" maxlength="6" bindblur="handleInputBlur" />
      <view class="code-actions">
        <view class="dialog-btn cancel-btn" bindtap="closeDialog">取消</view>
        <view class="dialog-btn confirm-btn" bindtap="verifyCode">确定</view>
      </view>
    </view>
  </view>
</view>
