page {
  background: #ffffff;
}

.container {
  padding: 24rpx;
  padding: 70rpx 24rpx 24rpx ;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  box-sizing: border-box;
}

.balance-card {
  border-radius: 24rpx;
  background: linear-gradient(135deg, #837adf 0%, #6c62c7 100%);
  padding: 30rpx;
  color: #fff;
}

.balance-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.balance-label {
  font-size: 30rpx;
}

.record-link {
  font-size: 24rpx;
  opacity: 0.92;
}

.balance-value {
  margin-top: 22rpx;
  font-size: 54rpx;
  font-weight: 700;
}

.section-title {
  margin-top: 50rpx;
  margin-bottom: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.amount-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.amount-item {
  width: calc((100% - 40rpx) / 3);
  min-height: 120rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f8f8;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 8rpx;
  background-color: rgba(237, 236, 236, 0.721)
}

.amount-item.active {
   background: linear-gradient(135deg, #837adf 0%, #6c62c7 100%);
}

.amount-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #2f2f2f;
  line-height: 1;
}

.amount-item.active .amount-text {
  color: #fff;
}

.gift-text {
  font-size: 28rpx;
  color: #b7b7b7;
  line-height: 1.1;
}

.amount-item.active .gift-text {
  color: rgba(255, 255, 255, 0.9);
}

.pay-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
}

.scene-tips {
  margin-top: 22rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  background: #fff1f1;
  color: #f06f6f;
  font-size: 28rpx;
  font-weight: 600;
}

.pay-item {
  height: 92rpx;
  border: 2rpx solid #ececec;
  border-radius: 999rpx;
  padding: 0 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
}

.pay-item.active {
  border-color: #6960c5;
}

.pay-name {
  font-size: 30rpx;
  color: #5a5a5a;
}

.radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #cfcfcf;
}

.radio.checked {
  background: #6960c5;
  border-color: #6960c5;
}

.submit-btn {
  margin-top: 60rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #837adf 0%, #6c62c7 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn.active {
  background: #6960c5;
}

.agreement {
  margin-top: 22rpx;
  text-align: center;
  color: #9d9d9d;
  font-size: 22rpx;
}

.agreement-link {
  color: #6960c5;
  font-weight: 600;
}
