<view class="container">
  <scroll-view class="store-scroll-view" scroll-y="true" enhanced="true" show-scrollbar="{{false}}">
    <view class="store-list">
      <view class="store-empty" wx:if="{{!stores.length}}">
        <text class="store-empty-title">暂无可选门店</text>
        <text class="store-empty-desc">请稍后再试，或检查网络与定位授权。</text>
      </view>

      <block wx:for="{{stores}}" wx:key="id">
        <view class="store-item {{item.isSelected ? 'store-item-selected' : ''}}">
          <view class="store-main" bindtap="onStoreSelect" data-id="{{item.id}}">
            <view class="store-left">
              <view class="store-header">
                <view class="store-name-row">
                  <t-icon name="location-filled" size="34rpx" color="#c48a58" />
                  <text class="store-name">{{item.name}}</text>
                </view>
                <t-icon name="chevron-right" size="28rpx" color="#b0a294" />
              </view>

              <text class="store-address">{{item.displayAddress || '门店地址待补充'}}</text>

              <view class="store-meta">
                <text class="store-business-time">营业时间 {{item.displayBusinessTime}}</text>
                <text class="store-tag" wx:if="{{item.displayTag}}">{{item.displayTag}}</text>
              </view>
            </view>

            <view class="store-right">
              <view class="store-cta">
                <text class="store-cta-title">去下单</text>
                <text class="store-cta-distance" wx:if="{{item.distanceText}}">{{item.distanceText}}</text>
                <text class="store-cta-distance store-cta-distance-muted" wx:else>选择门店</text>
              </view>

              <view class="store-actions">
                <view class="store-action-button" catchtap="onCallStore" data-id="{{item.id}}">
                  <t-icon name="call" size="34rpx" color="#43342a" />
                </view>
                <view class="store-action-button store-action-button-nav" catchtap="onNavigateStore" data-id="{{item.id}}">
                  <t-icon name="map-navigation" size="34rpx" color="#43342a" />
                </view>
              </view>
            </view>
          </view>

          <view class="store-selected-corner" wx:if="{{item.isSelected}}">
            <t-icon name="check" size="24rpx" color="#ffffff" />
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
