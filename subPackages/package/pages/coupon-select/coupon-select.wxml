<view class="container">
  <view class="list">
    <block wx:for="{{coupons}}" wx:key="id">
      <label class="coupon-item">
        <view class="info">
          <text class="title">{{item.cardName}}</text>
          <text class="sub">面额 ¥{{item.atm}} | 有效期至 {{item.endTime}}</text>
        </view>
        <radio class="radio" value="{{item.cardid || item.id}}" checked="{{selectedId === (item.cardid || item.id)}}"></radio>
      </label>
    </block>
  </view>
  <view class="footer">
    <button class="btn" bindtap="confirm">使用此优惠券</button>
  </view>
</view>
