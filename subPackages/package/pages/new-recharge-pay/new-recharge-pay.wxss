page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

.pay-container {
  padding: 40rpx 30rpx;
}

/* 顶部状态 */
.header-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}
.icon-safe {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}
.header-section .title {
  font-size: 26rpx;
  color: #888888;
}

/* 金额卡片 (采用蓝白相间的现代感设计) */
.amount-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(22, 119, 255, 0.05);
  margin-bottom: 30rpx;
}
.amount-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}
.amount-value {
  color: #FF5A00; /* 金额使用醒目的橙色系 */
  display: flex;
  align-items: baseline;
  justify-content: center;
}
.amount-value .symbol {
  font-size: 48rpx;
  font-weight: bold;
}
.amount-value .num {
  font-size: 80rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
}

/* 订单详情卡片 */
.detail-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}
.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}
.detail-row:last-child {
  margin-bottom: 0;
}
.detail-row .label {
  font-size: 28rpx;
  color: #999999;
}
.detail-row .value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 底部按钮 */
.footer-btn {
  margin-top: 100rpx;
  display: flex;
  justify-content: center;
}
.pay-btn {
  width: 90%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #1677FF; /* 微信/支付宝通用安全色：科技蓝 */
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 24rpx rgba(22, 119, 255, 0.25);
  transition: opacity 0.2s;
}
.pay-btn:active {
  opacity: 0.8;
}